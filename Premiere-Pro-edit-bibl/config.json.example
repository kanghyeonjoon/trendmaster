{
  "_설명": "이 파일을 config.json 으로 복사하면 프리셋보다 우선 적용됩니다. 바꾸고 싶은 값만 남기고 나머지는 지워도 됩니다.",
  "_프리셋_쓰는법": "config.json 없이 ./edit.sh \"영상.mp4\" --preset 공격  처럼 실행하면 보수/표준/공격 프리셋 사용",

  "MIN_SILENCE": 0.5,
  "PAD": 0.10,
  "HESITATION_MIN": 0.35,
  "REPEAT_GAP": 0.8,
  "FILLER_PHRASES": ["그러니까", "그니까", "뭐", "뭔가", "막", "약간", "좀"],
  "TARGET_LUFS": -14.0,
  "STT_MODEL": "large-v3",
  "CROSSFADE_FRAMES": 0,

  "_자막_줄길이": "한 자막 글자수. 세로(9:16) 영상은 지정 없으면 자동 8~16자(한 줄), 가로는 25~35자.",
  "SUB_MIN_CHARS": 8,
  "SUB_MAX_CHARS": 16,
  "SUB_KEEP_WHOLE": 18,

  "_고유명사_힌트": "받아쓰기가 자주 틀리는 이름을 적어두면 그 표기로 인식됩니다.",
  "STT_HINTS": ["리브힙의원"],

  "_확정치환": "그래도 틀리는 표기는 전사 직후 자동으로 바꿔치기 (조사·두어절 오인식 대응).",
  "REPLACE_MAP": {"리뷰 의원": "리브힙의원"},

  "_대본교정": "촬영 대본 경로. 있으면 대본과 대조해 오타를 자동 교정 (즉흥 발화는 안 건드림). CLI --script 가 우선.",
  "SCRIPT_FILE": "",

  "_환청억제": "무음 구간의 유령 자막 억제(VAD). 문장 끝이 잘려나가면 false로.",
  "STT_VAD": true
}
